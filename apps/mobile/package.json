{
  "name": "colloquia-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "node scripts/run-android.mjs",
    "prebuild": "node scripts/prebuild.mjs",
    "build:apk:debug": "node scripts/build-apk.mjs",
    "build:apk:release": "node scripts/build-apk.mjs --release",
    "lint": "eslint app src --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "ios": "expo run:ios",
    "generate:icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/source-serif-4": "^0.2.3",
    "@react-native-community/netinfo": "^11.4.1",
    "@shopify/flash-list": "1.7.1",
    "expo": "~52.0.0",
    "expo-application": "~6.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.0",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~15.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-screen-capture": "~7.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "nativewind": "^4.1.0",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-sse": "^1.2.1",
    "rn-emoji-keyboard": "^1.7.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^9",
    "eslint-config-expo": "^8",
    "typescript": "~5.6.0"
  }
}
