# Auth service
AUTH_DATABASE_URL=postgresql://colloquia:colloquia_dev_password@auth-db:5432/colloquia-auth?sslmode=disable
AUTH_GRPC_PORT=50051
AUTH_HTTP_PORT=8081

# Users service
USERS_DATABASE_URL=postgres://colloquia:colloquia_dev_password@users-db:5432/colloquia-users?sslmode=disable
USERS_GRPC_PORT=50052
USERS_HTTP_PORT=8082
USERS_GRPC_ADDRESS=users-service:50052

# Channels service
CHANNELS_DATABASE_URL=postgres://colloquia:colloquia_dev_password@channels-db:5432/colloquia-channels?sslmode=disable
CHANNELS_GRPC_PORT=50053
CHANNELS_HTTP_PORT=8083

# Messaging service
MESSAGING_DATABASE_URL=postgres://colloquia:colloquia_dev_password@messaging-db:5432/colloquia-messaging?sslmode=disable
MESSAGING_GRPC_PORT=50054
MESSAGING_HTTP_PORT=8084
CHANNELS_GRPC_ADDRESS=channels-service:50053

# Assist service
ASSIST_HTTP_PORT=8085
ASSIST_GRPC_PORT=50055
ASSIST_OLLAMA_BASE_URL=http://localhost:11434
ASSIST_OLLAMA_MODEL=qwen2.5:0.5b
ASSIST_OLLAMA_TIMEOUT_SECONDS=30
ASSIST_MESSAGING_GRPC_ADDRESS=localhost:50054
ASSIST_LLM_PROVIDER=ollama

# Web (NuxtJS)
NUXT_PUBLIC_API_BASE=http://localhost
NUXT_API_BASE=http://gateway:8000
