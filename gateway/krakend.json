{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Colloquia API Gateway",
  "port": 8000,
  "timeout": "10s",
  "extra_config": {
    "router": {
      "forwarded_by_client_ip": true,
      "return_error_msg": true
    },
    "telemetry/logging": {
      "level": "INFO",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    },
    "security/cors": {
      "allow_origins": [
        "*"
      ],
      "allow_methods": [
        "GET",
        "HEAD",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS"
      ],
      "allow_headers": [
        "Origin",
        "Authorization",
        "Content-Type",
        "Accept"
      ],
      "expose_headers": [
        "Content-Length",
        "Content-Type"
      ],
      "max_age": "12h",
      "allow_credentials": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/v1/auth/register",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": [
        "Content-Type"
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 20,
          "client_max_rate": 5,
          "strategy": "ip"
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/auth/register",
          "host": [
            "http://auth-service:8081"
          ],
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/auth/login",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": [
        "Content-Type"
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 20,
          "client_max_rate": 3,
          "strategy": "ip"
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/auth/login",
          "host": [
            "http://auth-service:8081"
          ],
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/auth/refresh",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": [
        "Content-Type"
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 60,
          "client_max_rate": 10,
          "strategy": "ip"
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/auth/refresh",
          "host": [
            "http://auth-service:8081"
          ],
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/v1/auth/logout",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://auth-service:8081/.well-known/jwks.json",
          "disable_jwk_security": true,
          "cache": true,
          "cache_duration": 900
        },
        "qos/ratelimit/router": {
          "max_rate": 60,
          "client_max_rate": 20,
          "strategy": "ip"
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/auth/logout",
          "host": [
            "http://auth-service:8081"
          ],
