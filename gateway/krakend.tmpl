{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Colloquia API Gateway",
  "port": 8000,
  "timeout": "30s",
  "extra_config": {
    "router": {
      "forwarded_by_client_ip": true,
      "return_error_msg": true,
      "write_timeout": "3m",
      "read_timeout": "30s",
      "idle_timeout": "3m"
    },
    "telemetry/logging": {
      "level": "INFO",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    },
    "security/cors": {
      "allow_origins": [
        "*"
      ],
      "allow_methods": [
        "GET",
        "HEAD",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS"
      ],
      "allow_headers": [
        "Origin",
        "Authorization",
        "Content-Type",
        "Accept"
      ],
      "expose_headers": [
        "Content-Length",
        "Content-Type"
      ],
      "max_age": "12h",
      "allow_credentials": false
    }
  },
  "endpoints": [
    {{ include "auth.json" }},
    {{ include "users.json" }},
    {{ include "channels.json" }},
    {{ include "messaging.json" }},
    {{ include "assist.json" }}
  ]
}
