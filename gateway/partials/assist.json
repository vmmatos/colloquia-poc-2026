{
  "endpoint": "/api/v1/assist/suggestions",
  "method": "POST",
  "timeout": "70s",
  "output_encoding": "no-op",
  "input_headers": [
    "Authorization",
    "Content-Type"
  ],
  "extra_config": {
    "auth/validator": {
      "alg": "RS256",
      "jwk_url": "http://auth-service:8081/.well-known/jwks.json",
      "disable_jwk_security": true,
      "cache": true,
      "cache_duration": 900
    },
    "qos/ratelimit/router": {
      "max_rate": 100,
      "client_max_rate": 10,
      "strategy": "ip"
    }
  },
  "backend": [
    {
      "url_pattern": "/api/v1/assist/suggestions",
      "host": [
        "http://assist-service:8085"
      ],
      "method": "POST",
      "encoding": "no-op"
    }
  ]
}
