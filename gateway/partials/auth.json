  "method": "POST",
  "output_encoding": "no-op",
  "input_headers": [
    "Authorization",
    "Content-Type"
  ],
  "extra_config": {
    "auth/validator": {
      "alg": "RS256",
      "jwk_url": "http://auth-service:8081/.well-known/jwks.json",
