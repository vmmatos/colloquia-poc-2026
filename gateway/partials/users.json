{
  "endpoint": "/api/v1/users",
  "method": "GET",
  "output_encoding": "no-op",
  "input_headers": ["Authorization"],
  "input_query_strings": ["limit", "offset"],
  "extra_config": {
    "auth/validator": {
      "alg": "RS256",
      "jwk_url": "http://auth-service:8081/.well-known/jwks.json",
      "disable_jwk_security": true,
      "cache": true,
      "cache_duration": 900
    },
    "qos/ratelimit/router": {
      "max_rate": 200,
      "client_max_rate": 50,
      "strategy": "ip"
    }
  },
  "backend": [
    {
      "url_pattern": "/api/v1/users",
      "host": ["http://users-service:8082"],
      "method": "GET",
      "encoding": "no-op"
    }
  ]
},
